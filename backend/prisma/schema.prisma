generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 家庭表
model Family {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  familyCode  String   @unique @map("family_code") @db.VarChar(20)
  settings    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       User[]
  tasks       Task[]
  weeklyPlans WeeklyPlan[]
  books       Book[]
  activeReadings ActiveReading[]
  achievements Achievement[]

  @@map("families")
}

// 用户表
model User {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(50)
  role         String   @db.VarChar(20) // child, parent
  avatar       String   @default("🐛") @db.VarChar(10)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  familyId     Int      @map("family_id")
  status       String   @default("active") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  family       Family   @relation(fields: [familyId], references: [id])
  weeklyPlans  WeeklyPlan[]
  dailyCheckins DailyCheckin[]
  readingLogs  ReadingLog[]
  activeReadings ActiveReading[]
  achievementLogs AchievementLog[]

  @@map("users")
}

// 任务配置模板（家长设置）
model Task {
  id           Int      @id @default(autoincrement())
  familyId     Int      @map("family_id")
  name         String   @db.VarChar(100)
  category     String   @db.VarChar(30) // school, extra, english, sports, chinese
  type         String   @db.VarChar(20) // fixed, flexible, follow
  timePerUnit  Int      @default(30) @map("time_per_unit") // 单次时长（分钟）
  weeklyRule   Json?    @map("weekly_rule") // 分配规则 {"exclude_days": [3], "only_weekend": true}
  tags         Json?    @default("{}") // 多维度标签 {"subject": "math", "format": ["paper", "tablet"], "participation": "independent", "difficulty": "basic"}
  appliesTo    Json?    @default("[]") @map("applies_to") // 适用孩子ID数组，空数组表示所有孩子
  sortOrder    Int      @default(0) @map("sort_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  family       Family   @relation(fields: [familyId], references: [id])
  weeklyPlans  WeeklyPlan[]

  @@map("tasks")
}

// 每周执行计划（发布后生成）
model WeeklyPlan {
  id         Int      @id @default(autoincrement())
  familyId   Int      @map("family_id")
  childId    Int      @map("child_id")
  taskId     Int      @map("task_id")
  target     Int      @default(1)       // 本周目标数量
  progress   Int      @default(0)       // 已完成数量
  weekNo     String   @map("week_no") @db.VarChar(10) // "2025-14"
  status     String   @default("active") @db.VarChar(20) // active, completed, expired
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  family     Family   @relation(fields: [familyId], references: [id])
  child      User     @relation(fields: [childId], references: [id])
  task       Task     @relation(fields: [taskId], references: [id])
  checkins   DailyCheckin[]

  @@map("weekly_plans")
}

// 每日打卡记录
model DailyCheckin {
  id         Int      @id @default(autoincrement())
  familyId   Int      @map("family_id")
  childId    Int      @map("child_id")
  taskId     Int      @map("task_id")
  planId     Int?     @map("plan_id")
  status     String   @db.VarChar(20) // completed, partial, postponed, not_involved, not_completed, makeup, advance
  value      Int?                                     // 完成数量
  checkDate  DateTime @map("check_date")
  createdAt  DateTime @default(now()) @map("created_at")

  child      User     @relation(fields: [childId], references: [id])
  plan       WeeklyPlan? @relation(fields: [planId], references: [id])

  @@map("daily_checkins")
}

// 图书表（图书馆 - 家庭藏书档案）
model Book {
  id            Int      @id @default(autoincrement())
  familyId      Int      @map("family_id")
  name          String   @db.VarChar(200)
  author        String   @default("") @db.VarChar(100)
  type          String   @default("fiction") @db.VarChar(30) // fiction, nonfiction, science, history
  characterTag  String   @default("") @map("character_tag") @db.VarChar(50) // 性格养成标签
  coverUrl      String   @default("") @map("cover_url") @db.VarChar(500)
  totalPages    Int      @default(0) @map("total_pages") // 书籍总页数
  readCount     Int      @default(0) @map("read_count") // 累计阅读次数
  status        String   @default("active") @db.VarChar(20)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  family        Family   @relation(fields: [familyId], references: [id])
  readingLogs   ReadingLog[]
  activeReadings ActiveReading[]

  @@map("books")
}

// 当前在读记录（阅读管理模块）
model ActiveReading {
  id            Int      @id @default(autoincrement())
  familyId      Int      @map("family_id")
  childId       Int      @map("child_id")
  bookId        Int      @map("book_id")
  readPages     Int      @default(0) @map("read_pages") // 已读页数
  readCount     Int      @default(0) @map("read_count") // 本次阅读次数
  status        String   @default("reading") @db.VarChar(20) // reading, completed
  startedAt     DateTime @default(now()) @map("started_at")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  family        Family   @relation(fields: [familyId], references: [id])
  child         User     @relation(fields: [childId], references: [id])
  book          Book     @relation(fields: [bookId], references: [id])
  progressLogs  ReadingProgressLog[]

  @@unique([childId, bookId, status]) // 一个孩子同一本书只能有一个在读记录
  @@map("active_readings")
}

// 阅读进度记录（每次更新进度都记录）
model ReadingProgressLog {
  id              Int      @id @default(autoincrement())
  familyId        Int      @map("family_id")
  childId         Int      @map("child_id")
  bookId          Int      @map("book_id")
  activeReadingId Int      @map("active_reading_id")
  pagesRead       Int      @map("pages_read") // 本次读的页数
  totalReadPages  Int      @map("total_read_pages") // 累计已读页数
  readDate        DateTime @map("read_date")
  createdAt       DateTime @default(now()) @map("created_at")

  activeReading   ActiveReading @relation(fields: [activeReadingId], references: [id])

  @@map("reading_progress_logs")
}

// 历史阅读记录（归档）
model ReadingLog {
  id         Int      @id @default(autoincrement())
  familyId   Int      @map("family_id")
  childId    Int      @map("child_id")
  bookId     Int      @map("book_id")
  pages      Int      @default(0)
  minutes    Int      @default(0)
  readDate   DateTime @map("read_date")
  createdAt  DateTime @default(now()) @map("created_at")

  child      User     @relation(fields: [childId], references: [id])
  book       Book     @relation(fields: [bookId], references: [id])

  @@map("reading_logs")
}

// 成就定义
model Achievement {
  id           Int      @id @default(autoincrement())
  familyId     Int      @map("family_id")
  icon         String   @default("🏆") @db.VarChar(10)
  name         String   @db.VarChar(50)
  description  String   @default("") @db.VarChar(200)
  condition    Json     @default("{}") // {"type": "streak_days", "value": 7}
  sortOrder    Int      @default(0) @map("sort_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  family       Family   @relation(fields: [familyId], references: [id])
  logs         AchievementLog[]

  @@map("achievements")
}

// 成就记录
model AchievementLog {
  id            Int      @id @default(autoincrement())
  familyId      Int      @map("family_id")
  childId       Int      @map("child_id")
  achievementId Int      @map("achievement_id")
  unlockedAt    DateTime @default(now()) @map("unlocked_at")

  child         User     @relation(fields: [childId], references: [id])
  achievement   Achievement @relation(fields: [achievementId], references: [id])

  @@map("achievement_logs")
}
