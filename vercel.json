{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "installCommand": "npm install && cd frontend && pnpm install && cd ../backend && npm install",
  "framework": null,
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/index.html"
    }
  ]
}
